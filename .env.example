# ─────────────────────────────────────────────
# 区块链节点 RPC（任意 EVM 兼容链）
# ─────────────────────────────────────────────
RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
# 示例：
# Ethereum Mainnet: https://mainnet.infura.io/v3/YOUR_KEY
# Polygon:          https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# Arbitrum:         https://arb1.arbitrum.io/rpc
# Anvil (本地):      http://localhost:8545

# ─────────────────────────────────────────────
# 账户私钥
# ─────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x           # 部署账户（forge script 使用）
OPERATOR_PRIVATE_KEY=0x           # 运营账户（后端服务：NAV 推送、赎回结算）
ORACLE_NODE=                      # 预言机节点地址（可选，默认用 deployer）
VAULT_OPERATOR=                   # Vault 运营地址（可选，默认用 deployer）
FEE_RECIPIENT=                    # 管理费收款地址

# ─────────────────────────────────────────────
# 合约地址（forge script 部署后填写）
# ─────────────────────────────────────────────
FACTORY_ADDRESS=
NAV_ORACLE_ADDRESS=
SPV_REGISTRY_ADDRESS=
USDT_ADDRESS=                     # 本地测试留空（自动部署 MockERC20）

# ─────────────────────────────────────────────
# 后端 Spring Boot 配置
# ─────────────────────────────────────────────
ADMIN_API_KEY=change-me-before-production
NAV_UPDATE_INTERVAL_MS=21600000       # NAV 推送间隔（默认 6 小时）
REDEMPTION_CHECK_INTERVAL_MS=300000   # 赎回检查间隔（默认 5 分钟）
