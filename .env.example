# ─────────────────────────────────────────────
# 区块链节点 RPC
# ─────────────────────────────────────────────
RPC_URL=https://hashkeychain-testnet.alt.technology

# ─────────────────────────────────────────────
# 账户私钥（部署 / 运营）
# ─────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x
OPERATOR_PRIVATE_KEY=0x

# ─────────────────────────────────────────────
# 合约地址（deploy.ts 执行后填写）
# ─────────────────────────────────────────────
FACTORY_ADDRESS=
NAV_ORACLE_ADDRESS=
USDT_ADDRESS=

# ─────────────────────────────────────────────
# 其他链 RPC
# ─────────────────────────────────────────────
HASHKEY_TESTNET_RPC=https://hashkeychain-testnet.alt.technology
HASHKEY_MAINNET_RPC=https://mainnet.hsk.xyz
ETHEREUM_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─────────────────────────────────────────────
# 后端 API 配置
# ─────────────────────────────────────────────
PORT=3000
ADMIN_API_KEY=change-me-before-production
NODE_ENV=development

# ─────────────────────────────────────────────
# Gas 报告（可选）
# ─────────────────────────────────────────────
REPORT_GAS=false
